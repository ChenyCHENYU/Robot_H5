# must start with VITE_
VITE_ENV = 'development'

VITE_GLOB_APP_TITLE = CHENY

# 只在开发模式中被载入
VITE_PORT = 8888

# 网站根目录
VITE_PUBLIC_PATH = /robot-h5/

# 是否开启mock
VITE_USE_MOCK = true

# 是否hash路由
VITE_HASH_ROUTE = false

# 构建输出目录
VITE_OUTPUT_DIR = 'dist'

# 跨域代理，可以配置多个，请注意不要换行
# /appApi → 172.28.99.172:9000  业务后端服务（直连）
# /pcApi  → 172.18.248.205:80   PC端网关（菜单/登录/权限复用）
VITE_PROXY = [["/appApi","http://172.28.99.172:9000"],["/pcApi","http://172.18.248.205"],["/upload","http://172.28.99.172:9000/upload"]]

# API 接口地址（开发环境通过 proxy 代理，此处留空）
VITE_GLOB_API_URL =

# 接口前缀
VITE_GLOB_API_URL_PREFIX = /appApi

# PC端网关前缀（菜单/登录/权限接口）
VITE_GLOB_PC_API_PREFIX = /pcApi

# 图片上传地址
VITE_GLOB_UPLOAD_URL =

# 图片前缀地址
VITE_GLOB_IMG_URL_PREFIX =

#是否启用gzip压缩或brotli压缩
#可选:gzip | brotli | none
#如果你需要多个表单，你可以使用“，”来分隔
VITE_BUILD_COMPRESS = 'gzip'

# 使用压缩时是否删除原始文件，默认为false
VITE_BUILD_COMPRESS_DELETE_ORIGIN_FILE = true
