# ==============================
# Vercel 演示环境 (.env.vercel)
# 静态站点 + Mock 数据，无需真实后端
# ==============================

# 环境标识
VITE_ENV = 'production'

# 应用名称
VITE_GLOB_APP_TITLE = CHENY

# 网站根目录
VITE_PUBLIC_PATH = /

# 开启 Mock（演示站使用模拟数据）
VITE_USE_MOCK = true

# Hash 路由模式
VITE_HASH_ROUTE = false

# 构建输出目录
VITE_OUTPUT_DIR = 'dist'

# Mock 模式下无需真实 API 地址
VITE_GLOB_API_URL =
VITE_GLOB_API_URL_PREFIX = /api
VITE_GLOB_APP_ID = robot-h5
VITE_GLOB_UPLOAD_URL =
VITE_GLOB_IMG_URL_PREFIX =
