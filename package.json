{
  "name": "robot-h5",
  "version": "1.3.0",
  "description": "Vue 3 + Vite 7 + TypeScript 企业级移动端 H5 应用框架",
  "private": true,
  "type": "module",
  "license": "UNLICENSED",
  "author": {
    "name": "CHENY",
    "email": "cheny@agile-team.cn"
  },
  "repository": {
    "type": "git",
    "url": "https://git.yourcompany.com/robot/robot-h5.git"
  },
  "keywords": [
    "vue3",
    "vite7",
    "h5",
    "mobile",
    "typescript",
    "enterprise"
  ],
  "scripts": {
    "prepare": "husky",
    "dev": "vite --mode development",
    "dev:prod": "vite --mode production",
    "build:test": "vue-tsc --noEmit && vite build --mode test",
    "build:prod": "vue-tsc --noEmit && vite build --mode production",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "pnpm run build:prod && vite preview --port 5050",
    "preview:dist": "vite preview",
    "clean": "rimraf node_modules && rimraf .eslintcache && rimraf dist",
    "type-check": "vue-tsc --noEmit",
    "lint": "eslint . --fix",
    "cz": "git-cz",
    "deps:check": "pnpm outdated",
    "deps:update": "pnpm update --latest",
    "preinstall": "npx only-allow pnpm",
    "release": "standard-version",
    "release:minor": "standard-version --release-as minor",
    "release:major": "standard-version --release-as major",
    "release:patch": "standard-version --release-as patch",
    "release:first": "standard-version --first-release"
  },
  "dependencies": {
    "@iconify/vue": "5.0.0",
    "@miracle-web/utils": "^0.0.6",
    "@unocss/reset": "^66.5.1",
    "@vant/touch-emulator": "^1.4.0",
    "@vueuse/core": "^13.9.0",
    "disable-devtool": "^0.3.9",
    "echarts": "^6.0.0",
    "mitt": "^3.0.1",
    "nprogress": "^0.2.0",
    "pinia": "^3.0.3",
    "pinia-plugin-persistedstate": "^4.5.0",
    "vant": "^4.9.14",
    "vue": "^3.5.21",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@iconify-json/ic": "*",
    "@iconify-json/ph": "*",
    "@robot-admin/git-standards": "1.0.3",
    "@types/mockjs": "^1.0.10",
    "@types/node": "^24.4.0",
    "@types/nprogress": "^0.2.3",
    "@typescript-eslint/eslint-plugin": "8.58.1",
    "@typescript-eslint/parser": "8.58.1",
    "@unocss/preset-icons": "^66.5.1",
    "@unocss/preset-rem-to-px": "^66.5.1",
    "@unocss/transformer-directives": "^66.5.1",
    "@unocss/transformer-variant-group": "^66.5.1",
    "@vant/auto-import-resolver": "^1.2.1",
    "@vitejs/plugin-legacy": "^7.2.1",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vitejs/plugin-vue-jsx": "^5.1.1",
    "@vue/eslint-config-typescript": "14.7.0",
    "autoprefixer": "^10.4.21",
    "commitizen": "4.3.1",
    "cz-customizable": "7.5.4",
    "eslint": "10.2.0",
    "eslint-plugin-vue": "10.8.0",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "mockjs": "^1.1.0",
    "postcss": "^8.5.6",
    "postcss-mobile-forever": "^5.0.0",
    "rimraf": "^5.0.0",
    "rollup-plugin-visualizer": "^6.0.3",
    "sass": "^1.92.1",
    "standard-version": "9.5.0",
    "typescript": "~5.9.2",
    "unocss": "^66.5.1",
    "unplugin-auto-import": "^20.1.0",
    "unplugin-vue-components": "^29.0.0",
    "vite": "^7.1.5",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-html": "^3.2.2",
    "vite-plugin-mock": "^2.9.8",
    "vite-plugin-progress": "^0.0.7",
    "vite-plugin-pwa": "1.2.0",
    "vite-plugin-svg-icons": "^2.0.1",
    "vue-tsc": "^3.0.7"
  },
  "engines": {
    "node": "^20.0.0 || >=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-customizable"
    },
    "cz-customizable": {
      "config": ".cz-config.cjs"
    }
  },
  "lint-staged": {
    "src/**/*.{js,jsx,ts,tsx,vue}": [
      "eslint --fix --no-cache"
    ]
  }
}
