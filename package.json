        "@iconify-json/carbon": "*",
        "@iconify-json/ic": "*",
        "@iconify-json/iconamoon": "*",
        "@iconify-json/mage": "*",
        "@iconify-json/mdi": "*",
        "@iconify-json/mingcute": "*",
        "@iconify-json/ph": "*",
        "@iconify-json/tabler": "*",
        "@nabla/vite-plugin-eslint": "^2.0.6",
        "@types/mockjs": "^1.0.10",
        "@types/node": "^24.4.0",
        "@types/nprogress": "^0.2.3",
        "@typescript-eslint/eslint-plugin": "^8.43.0",
        "@typescript-eslint/parser": "^8.43.0",
        "@unocss/preset-icons": "^66.5.1",
        "@unocss/preset-rem-to-px": "^66.5.1",
