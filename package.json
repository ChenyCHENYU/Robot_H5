{
    "name": "vite-vue3-h5-template",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "author": {
        "name": "CHENY"
    },
    "scripts": {
        "prepare": "husky",
        "dev": "vite --mode development",
        "prod": "vite --mode production",
        "build:test": "vue-tsc --noEmit && vite build --mode test",
        "build:prod": "vue-tsc --noEmit && vite build --mode production",
        "build": "vue-tsc --noEmit && vite build",
        "preview": "pnpm run build:prod && vite preview --port 5050",
        "preview:dist": "vite preview",
        "clean": "rimraf node_modules && rimraf .eslintcache && rimraf dist",
        "type-check": "vue-tsc --noEmit",
        "lint": "eslint",
        "lint:fix": "eslint --fix",
        "lint:lint-staged": "lint-staged",
        "format": "prettier . --write",
        "format:check": "prettier . --check",
        "deps:check": "pnpm outdated",
        "deps:update": "pnpm update --latest",
        "preinstall": "npx only-allow pnpm"
    },
    "dependencies": {
        "@iconify/vue": "5.0.0",
        "@miracle-web/utils": "^0.0.6",
        "@unocss/reset": "^66.5.1",
        "@vant/touch-emulator": "^1.4.0",
        "@vueuse/core": "^13.9.0",
        "disable-devtool": "^0.3.9",
        "echarts": "^6.0.0",
        "mitt": "^3.0.1",
        "mockjs": "^1.1.0",
        "nprogress": "^0.2.0",
        "pinia": "^3.0.3",
        "pinia-plugin-persistedstate": "^4.5.0",
        "vant": "^4.9.14",
        "vue": "^3.5.21",
        "vue-router": "^4.5.1"
    },
    "devDependencies": {
        "@commitlint/cli": "^19.8.1",
        "@commitlint/config-conventional": "^19.6.0",
        "@eslint/js": "^9.35.0",
